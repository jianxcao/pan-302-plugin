{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "api_key": {
      "type": "string",
      "title": "节点 API Key"
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "title": "CloudHub API URL"
    },
    "node_id": {
      "type": "string",
      "title": "节点 ID"
    },
    "public_base_url": {
      "type": "string",
      "format": "uri",
      "title": "节点公开 URL"
    },
    "batch_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500,
      "default": 500
    },
    "include_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "包含路径",
      "description": "只有包含在这个数组内的路径才会通知 CloudHub，留空则通知所有路径"
    },
    "use_media_added_event": {
      "type": "boolean",
      "title": "使用媒体库新增事件",
      "description": "开启后使用 Emby/Jellyfin 媒体新增事件推送；关闭时使用延迟 120 秒的 STRM 新增事件。",
      "default": false
    }
  },
  "required": [
    "api_key",
    "base_url",
    "node_id"
  ],
  "additionalProperties": false
}
