{
  "schemaVersion": 1,
  "name": "cloudhub-push",
  "version": "1.0.0",
  "displayName": "CloudHub 资源推送",
  "description": "检测到 STRM 创建、覆盖、移动、复制或删除时，自动将对应网盘文件信息推送到 CloudHub",
  "author": "media302",
  "abi": "pan302-plugin-abi/v2",
  "wasm": "plugin.wasm",
  "configVersion": 1,
  "events": [
    "strm.created",
    "strm.overwritten",
    "strm.deleted",
    "strm.renamed",
    "strm.moved",
    "strm.copied"
  ],
  "permissions": [
    "log.write",
    "config.read",
    "http.request",
    "event.strm.read"
  ],
  "ui": {
    "manifest": "ui/manifest.json",
    "mode": "trusted-esm"
  }
}